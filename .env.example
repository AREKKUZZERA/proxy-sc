# Required
SOUNDCLOUD_CLIENT_ID=

# Optional: user URL for /api/dashboard
SOUNDCLOUD_USER_URL=https://soundcloud.com/arekkuzzera

# Optional: track URL for /api/plays
SOUNDCLOUD_TRACK_URL=https://soundcloud.com/arekkuzzera/psycho-dreams-hardstyle-remix

# CORS: '*' or comma-separated allowlist
ALLOWED_ORIGINS=*

# Resilience
SC_TIMEOUT_MS=8000

# Cache
SC_CACHE_TTL_SECONDS=300
SC_PLAYS_CACHE_TTL_SECONDS=60

# Best-effort per-instance rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Pagination and response bounds for /api/dashboard
SC_TRACK_PAGE_SIZE=200
SC_MAX_TRACK_PAGES=10
SC_MAX_TRACKS_TOTAL=2000
SC_MAX_TRACKS_IN_RESPONSE=200

# Debug
DEBUG_PROXY_SC=0
